---
interface Props {
  type: string;
  title: string;
  body: string;
  publisher?: string;
  href: string;
}

const { type, title, body, publisher, href } = Astro.props;
const isExternal = href.startsWith('http');
---

<div class="insight-item reveal">
  <p class="insight-tag">{type}</p>
  <h3><a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>{title}</a></h3>
  <p class="insight-body">{body}</p>
  {publisher && <p class="insight-publisher">{publisher}</p>}
</div>

<style>
  .insight-item {
    background: var(--white);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .insight-tag {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--body);
    border: 0.5px solid var(--lightgrey);
    padding: 4px 8px;
    display: inline-block;
    align-self: flex-start;
  }

  h3 {
    font-family: 'Archivo Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--charcoal);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  h3 a {
    color: inherit;
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  .insight-body {
    font-family: 'Archivo', sans-serif;
    font-size: 13px;
    line-height: 1.7;
    color: var(--body);
    flex: 1;
  }

  .insight-publisher {
    font-family: 'Archivo', sans-serif;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--midgrey);
  }
</style>
