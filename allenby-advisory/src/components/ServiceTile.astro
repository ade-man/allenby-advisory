---
interface Props {
  number: string;
  category: string;
  title: string;
  body: string;
  href: string;
}

const { number, category, title, body, href } = Astro.props;
---

<div class="service-tile reveal">
  <p class="tile-num">{number} — {category}</p>
  <h3>{title}</h3>
  <p>{body}</p>
  <a href={href}>Learn more</a>
</div>

<style>
  .service-tile {
    background: var(--white);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tile-num {
    font-family: 'Archivo', sans-serif;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--midgrey);
  }

  h3 {
    font-family: 'Archivo Condensed', sans-serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--charcoal);
    letter-spacing: 0.01em;
    line-height: 1.15;
  }

  p {
    font-family: 'Archivo', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: var(--body);
    flex: 1;
  }

  a {
    font-family: 'Archivo', sans-serif;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    align-self: flex-start;
    margin-top: auto;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
