---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionLabel from '../components/SectionLabel.astro';
import CaseCard from '../components/CaseCard.astro';
import { BOOKING_URL } from '../config';
---

<Base
  title="Client Successes — Allenby Advisory"
  description="Case studies from event technology projects across navigation, meetings programmes, lead capture and global research."
>
  <Nav />

  <main>

    <!-- PAGE HEADER -->
    <section class="page-header">
      <div class="section-inner">
        <SectionLabel text="Recent work" />
        <h1 class="page-h1">Client Successes</h1>
        <p class="page-intro">Every project starts with a problem. Here's how event teams solved theirs.</p>
      </div>
    </section>

    <!-- OBJECTIVES SECTION -->
    <section class="objectives-section reveal" id="objectives">
      <div class="section-inner">
      <SectionLabel text="Case studies by objective" />
      <h2 class="objectives-h2">What are you trying to achieve?</h2>
      <p class="objectives-intro">Most conversations start with a problem, not a project type. The work below is grouped by the kind of outcome event teams have come to us for — click through to the case study that's closest to your situation.</p>

      <!-- Objective 01 -->
      <div class="objective-row reveal">
        <div class="objective-left">
          <span class="objective-eyebrow">Objective 01</span>
          <h3>Launch or scale a digital product that drives revenue</h3>
        </div>
        <div class="objective-refs">
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/clarion-ai-assistant/">Clarion Events</a>
            <span class="objective-ref-hook">Deployed an AI matchmaking and concierge assistant across seven iterations — recognised with a leading industry innovation award.</span>
            <span class="objective-ref-badge">TSNN Best Innovation (B2C) 2025</span>
          </div>
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/incosmetics-global">Incosmetics Global</a>
            <span class="objective-ref-hook">Scaled a niche feature-zone product show-wide into an NFC lead capture system — and created a new exhibitor revenue stream.</span>
            <span class="objective-ref-badge">4× increase in paying exhibitors</span>
          </div>
        </div>
      </div>

      <!-- Objective 02 -->
      <div class="objective-row reveal">
        <div class="objective-left">
          <span class="objective-eyebrow">Objective 02</span>
          <h3>Unify fragmented systems and get your data working</h3>
        </div>
        <div class="objective-refs">
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/global-banking-markets/">Global Banking Markets</a>
            <span class="objective-ref-hook">Rebuilt the technology stack around HubSpot — replacing a fragmented set of spreadsheets, legacy CRM and disconnected tools with a unified, automated data platform.</span>
            <span class="objective-ref-badge">Single source of truth across every global event</span>
          </div>
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/connect">Connect (SABCO Group)</a>
            <span class="objective-ref-hook">Designed a HubSpot-based commercial platform for a UAE event business — structured deal configuration, clean data architecture and a sales process built to scale.</span>
            <span class="objective-ref-badge">A commercial engine built for scale</span>
          </div>
        </div>
      </div>

      <!-- Objective 03 -->
      <div class="objective-row reveal">
        <div class="objective-left">
          <span class="objective-eyebrow">Objective 03</span>
          <h3>Understand your audience through evidence, not assumption</h3>
        </div>
        <div class="objective-refs">
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/rx-global-research">RX Global</a>
            <span class="objective-ref-hook">Led a global research programme across ten countries that produced an award-winning framework for understanding attendee needs.</span>
            <span class="objective-ref-badge">88% awareness amongst senior event managers</span>
          </div>
        </div>
      </div>

      <!-- Objective 04 -->
      <div class="objective-row reveal">
        <div class="objective-left">
          <span class="objective-eyebrow">Objective 04</span>
          <h3>Help visitors navigate a complex event</h3>
        </div>
        <div class="objective-refs">
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/equiphotel">Equiphotel Paris</a>
            <span class="objective-ref-hook">Turned persistent negative navigation feedback into a validated, multi-year improvement programme with evidence for ongoing investment.</span>
            <span class="objective-ref-badge">100% growth in app adoption</span>
          </div>
        </div>
      </div>

      <!-- Objective 05 -->
      <div class="objective-row reveal">
        <div class="objective-left">
          <span class="objective-eyebrow">Objective 05</span>
          <h3>Run structured business meetings inside a live event</h3>
        </div>
        <div class="objective-refs">
          <div class="objective-ref">
            <a class="objective-ref-client" href="/client-successes/imbibe">Imbibe Live London</a>
            <span class="objective-ref-hook">Delivered a credible 1-2-1 meetings programme inside a show known for its convivial, socially-dominated atmosphere.</span>
            <span class="objective-ref-badge">Serious meetings. Party atmosphere.</span>
          </div>
        </div>
      </div>

      </div><!-- /.section-inner -->
    </section>

    <!-- PROJECT INDEX -->
    <section class="index-section">
      <div class="section-inner">
        <p class="index-label">Browse all client successes</p>
        <div class="index-grid">
          <CaseCard
            result="TSNN Best Innovation (B2C) 2025"
            title="Clarion Events — AI Assistant product development"
            eventTag="7 iterations · Europe and US · B2B and B2C"
            body="An AI matchmaking and concierge assistant was developed across seven iterations — deployed at live events in Europe and the US, and recognised with a leading industry innovation award."
            href="/client-successes/clarion-ai-assistant"
          />
          <CaseCard
            result="Single source of truth across every global event"
            title="Global Banking Markets — HubSpot as the central data platform"
            eventTag="Global · Financial conferences and festivals · Multi-country"
            body="We rebuilt the technology stack around HubSpot — replacing a fragmented set of spreadsheets, legacy CRM and disconnected tools with a unified, automated data platform."
            href="/client-successes/global-banking-markets"
          />
          <CaseCard
            result="A commercial engine built for scale"
            title="Connect (SABCO Group) — Event sales operations"
            eventTag="UAE · Conferences · B2B sponsorship"
            body="We designed and delivered a HubSpot-based commercial platform that turned fragmented tools and manual pricing into a structured, scalable sales operation."
            href="/client-successes/connect"
          />
          <CaseCard
            result="4× increase in paying exhibitors"
            title="Incosmetics Global — Lead Capture Strategy"
            eventTag="Paris / Barcelona · Cosmetics ingredients · Trade show"
            body="A niche feature-zone product was scaled show-wide into an NFC lead capture system — and turned into a new exhibitor revenue stream."
            href="/client-successes/incosmetics-global"
          />
          <CaseCard
            result="88% awareness amongst senior event managers"
            title="RX Global — Attendee Behavioural Archetypes"
            eventTag="Global · 68 events · 10 countries"
            body="A global research programme produced an award-winning framework for understanding attendee needs — adopted across every business unit worldwide."
            href="/client-successes/rx-global-research"
          />
          <CaseCard
            result="100% growth in app adoption"
            title="Equiphotel Paris — Visitor Navigation"
            eventTag="Paris · Trade show · 6 halls"
            body="Turned persistent negative visitor feedback on navigation into a validated, multi-year improvement programme."
            href="/client-successes/equiphotel"
          />
          <CaseCard
            result="Serious meetings. Party atmosphere."
            title="Imbibe Live London — 1-2-1 Meetings"
            eventTag="London · On-trade drinks show · B2B"
            body="Delivered structured, measurable business meetings inside a show known for its vibrant, sociable atmosphere."
            href="/client-successes/imbibe"
          />
        </div>
      </div>
    </section>

    <!-- FOOTER CTA -->
    <div class="dark-section">
      <div class="cta-inner">
        <h2>Working on Something Similar?</h2>
        <p>Whether you're launching a meetings programme, tackling navigation, or thinking through your next digital initiative — Ade would welcome the conversation.</p>
        <div style="margin-top: 32px;">
          <Button label="Book a free 30-minute call" href={BOOKING_URL} variant="light" external={true} />
        </div>
      </div>
    </div>

  </main>

  <Footer />
</Base>

<style>
  .page-header { background: var(--offwhite); }

  .page-h1 {
    font-family: 'Archivo Condensed', sans-serif;
    font-weight: 700;
    font-size: 52px;
    line-height: 1.06;
    letter-spacing: 0.01em;
    color: var(--charcoal);
    margin-bottom: var(--space-md);
  }

  .page-intro {
    max-width: 560px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--body);
  }

  .index-section {
    border-top: 0.5px solid var(--lightgrey);
  }

  .index-label {
    font-family: 'Archivo', sans-serif;
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--midgrey);
    margin-bottom: 24px;
  }

  .index-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  /* Footer CTA */
  .dark-section { padding: var(--space-2xl) 0; }

  .cta-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-h1 { font-size: 34px; }
    .index-grid { grid-template-columns: 1fr; }
  }
</style>
